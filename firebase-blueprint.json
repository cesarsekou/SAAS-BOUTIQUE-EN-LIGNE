{
  "entities": {
    "User": {
      "title": "User",
      "description": "A seller on the platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "storeName": { "type": "string" },
        "storeSlug": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "themeColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "textColor": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "storeName", "storeSlug", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product for sale in a user's store.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["storeId", "name", "price", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer in a store.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "totalAmount": { "type": "number" },
        "deliveryMethod": { "type": "string", "enum": ["pickup", "delivery"] },
        "deliveryAddress": { "type": "string" },
        "deliveryCity": { "type": "string" },
        "deliveryNeighborhood": { "type": "string" },
        "deliveryCost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "items": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["storeId", "customerName", "customerPhone", "totalAmount", "status", "deliveryMethod", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Stores products."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Stores orders placed in stores."
    }
  }
}
