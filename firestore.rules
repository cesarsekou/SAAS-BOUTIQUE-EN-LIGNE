rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction pour vérifier si l'utilisateur est le propriétaire de la boutique
    function isStoreOwner(storeId) {
      return request.auth != null && request.auth.uid == storeId;
    }

    // Collection Users (Les boutiques)
    match /users/{userId} {
      // N'importe qui peut lire les infos de la boutique
      allow read: if true;
      // Seul le propriétaire peut modifier ses paramètres
      allow write: if isStoreOwner(userId);
    }

    // Collection Products
    match /products/{productId} {
      // Tout le monde peut voir les produits
      allow read: if true;
      // Seul le marchand peut ajouter/modifier/supprimer ses propres produits
      // Lors d'un achat, on autorise exceptionnellement la modification du stock (règle simplifiée, l'idéal est une Cloud Function)
      allow create, delete: if isStoreOwner(request.resource.data.storeId) || isStoreOwner(resource.data.storeId);
      allow update: if true; // Pour permettre la mise à jour du stock lors d'une commande
    }

    // Collection Orders
    match /orders/{orderId} {
      // Les clients peuvent créer une commande (pas besoin d'être connecté)
      allow create: if true;
      
      // Seul le marchand peut lire et mettre à jour le statut des commandes de sa boutique
      allow read, update, delete: if isStoreOwner(resource.data.storeId);
    }
  }
}
